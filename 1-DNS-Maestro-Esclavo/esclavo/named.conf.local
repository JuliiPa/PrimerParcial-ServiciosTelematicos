// Configuración DNS Esclavo - Parcial Servicios Telemáticos
// Punto 1

zone "empresa.local" {
        type slave;
        file "/var/cache/bind/db.empresa.local";
        masters {192.168.50.3 key empresa-transfer; };
};

zone "50.168.192.in-addr.arpa" {
        type slave;
        file "/var/cache/bind/db.192.168.50";
        masters { 192.168.50.3 key empresa-transfer; };
};
